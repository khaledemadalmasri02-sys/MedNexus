# Production environment configuration for ankeng.com
# Copy this to .env and fill in your values

NODE_ENV=production
PORT=3001
DATABASE_URL=./data/sqlite.db
LOG_LEVEL=info

# OpenRouter API key (required for AI features)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# AI Models
AI_TEXT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_VISION_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_QBANK_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_EXPLAIN_MODEL=cohere/north-mini-code:free


# App URL (your domain)
APP_URL=https://ankeng.com

# Agent workspace path
AGENT_WORKSPACE_PATH=./workspaces

# Free tier limits
FREE_MAX_DECKS=10
FREE_MAX_CARDS_PER_DECK=100

# JWT secret (generate a random string)
JWT_SECRET=your-random-jwt-secret-here

# Session secret (generate a random string)
SESSION_SECRET=your-random-session-secret-here
