# Server Configuration
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=./data/sqlite.db

# AI Provider Keys (at least one required for AI features)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
OLLAMA_CLOUD_API_KEY=your_ollama_key_here

# AI Model Configuration
AI_TEXT_MODEL=openrouter/anthropic/claude-3.5-sonnet:free
AI_VISION_MODEL=openrouter/anthropic/claude-3.5-sonnet:free
AI_QBANK_MODEL=openrouter/anthropic/claude-3.5-sonnet:free
AI_EXPLAIN_MODEL=openrouter/anthropic/claude-3.5-sonnet:free

# Admin
ADMIN_SECRET_KEY=your_admin_secret_here

# App URLs (for CORS)
APP_URL=http://localhost:3000

# Google OAuth Web client ID for Sign in with Google
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Agent Workspace
AGENT_WORKSPACE_PATH=./workspaces

# Free Tier Limits
FREE_MAX_DECKS=10
