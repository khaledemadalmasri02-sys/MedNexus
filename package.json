{
  "name": "mednexus-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MedNexus API rewritten for Cloudflare Workers + D1 (SQLite) + Workers Assets (SPA)",
  "main": "src/worker.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "migrate:generate": "drizzle-kit generate",
    "migrate:apply:local": "wrangler d1 migrations apply mednexus-db --local",
    "migrate:apply": "wrangler d1 migrations apply mednexus-db",
    "db:create": "wrangler d1 create mednexus-db",
    "seed:library": "node scripts/seed-library.mjs",
    "build:frontend": "node scripts/copy-frontend.mjs",
    "dev": "npm run build:frontend && wrangler dev",
    "deploy": "npm run build:frontend && wrangler deploy",
    "tunnel": "node scripts/tunnel.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "wrangler": "^3.114.17"
  }
}
