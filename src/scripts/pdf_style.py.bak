#!/usr/bin/env python3
"""
Universal PDF Style Module for Professional Medical Exam PDFs

Features:
- 24-color palette for chapters
- Chapter banners, section headers, sub-headers
- Content boxes (KTP, MCQ, IMPORTANT, OSCE)
- Question boxes (Past Paper style)
- Professional tables
- Cover page
- Two-pass build for TOC
- Auto font discovery (DejaVu, Helvetica fallback)

Usage:
    from pdf_style import PDFStyle, chapter_banner, section_header, ...
"""

import os
import re
from pathlib import Path
from reportlab.lib.pagesizes import A4
from reportlab.lib.units import mm
from reportlab.lib.colors import Color, HexColor, white, black
from reportlab.lib.enums import TA_CENTER, TA_LEFT, TA_JUSTIFY
from reportlab.platypus import (
    SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle,
    PageTemplate, Frame, HRFlowable, KeepTogether, Flowable
)
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.pdfbase import pdfmetrics
from reportlab.pdfbase.ttfonts import TTFont
from reportlab.pdfbase.cidfonts import UnicodeCIDFont


# ═══════════════════════════════════════════════════════════════════════════
# 24-COLOR PALETTE
# ═══════════════════════════════════════════════════════════════════════════

DEFAULT_COLORS = [
    "#1A5276",  # 0: Deep Blue
    "#117A65",  # 1: Teal
    "#7D3C98",  # 2: Purple
    "#C0392B",  # 3: Red
    "#D4AC0D",  # 4: Gold
    "#2E86C1",  # 5: Sky Blue
    "#27AE60",  # 6: Green
    "#E67E22",  # 7: Orange
    "#8E44AD",  # 8: Violet
    "#16A085",  # 9: Emerald
    "#F39C12",  # 10: Amber
    "#2C3E50",  # 11: Dark Blue
    "#E74C3C",  # 12: Bright Red
    "#3498DB",  # 13: Light Blue
    "#2ECC71",  # 14: Light Green
    "#9B59B6",  # 15: Amethyst
    "#F1C40F",  # 16: Yellow
    "#E91E63",  # 17: Pink
    "#00BCD4",  # 18: Cyan
    "#FF5722",  # 19: Deep Orange
    "#607D8B",  # 20: Blue Gray
    "#795548",  # 21: Brown
    "#4CAF50",  # 22: Material Green
    "#FF9800",  # 23: Material Orange
]


def get_color(index: int) -> Color:
    """Get color from palette by index (wraps around)."""
    hex_color = DEFAULT_COLORS[index % len(DEFAULT_COLORS)]
    return HexColor(hex_color)


def tint_color(hex_color: str, tint_percent: float = 0.1) -> Color:
    """Create a tinted version of a color (for backgrounds)."""
    c = HexColor(hex_color)
    r, g, b = c.red, c.green, c.blue
    # Mix with white
    r = int(r + (1 - r) * (1 - tint_percent$
    g = int(g + (1 - g) * (1 - tint_percent$
    b = int(b + (1 - b) * (1 - tint_percent$
    return Color(r, g, b)


# ═══════════════════════════════════════════════════════════════════════════
# FONT DISCOVERY AND REGISTRATION
# ═══════════════════════════════════════════════════════════════════════════

FONTS_REGISTERED = False


def register_fonts():
    """Auto-discover and register DejaVu fonts, fallback to Helvetica."""
    global FONTS_REGISTERED
    if FONTS_REGISTERED:
        return

    # Common font paths to search
    font_paths = [
        "/usr/share/fonts/truetype/dejavu",
        "/usr/share/fonts/TTF",
        "/usr/share/fonts",
        "/System/Library/Fonts",
        "/Library/Fonts",
        os.path.expanduser("~/.fonts"),
        os.path.expanduser("~/Library/Fonts"),
        "C:/Windows/Fonts",
    ]

    # Also search in current directory and common locations
    for root, dirs, files in os.walk("/usr/share/fonts"):
        for f in files:
            if f.lower().startswith("dejaVu") and f.lower().endswith(".ttf"):
                font_paths.append(root)
                break

    font_files = {
        "DejaVu": None,
        "DejaVu-Bold": None,
        "DejaVu-Italic": None,
        "DejaVu-BoldItalic": None,
        "DejaVuSerif-Bold": None,
    }

    # Search for fonts
    for font_dir in font_paths:
        if not os.path.exists(font_dir):
            continue
        for f in os.listdir(font_dir):
            fpath = os.path.join(font_dir, f)
            if not os.path.isfile(fpath):
                continue
            fname = f.lower()
            if "dejavu" in fname and fname.endswith(".ttf"):
                if "bold" in fname and "italic" in fname:
                    font_files["DejaVu-BoldItalic"] = fpath
                elif "bold" in fname and "serif" not in fname:
                    font_files["DejaVu-Bold"] = fpath
                elif "italic" in fname and "serif" not in fname:
                    font_files["DejaVu-Italic"] = fpath
                elif "serif" in fname and "bold" in fname:
                    font_files["DejaVuSerif-Bold"] = fpath
                elif "bold" not in fname and "italic" not in fname and "serif" not in fname:
                    font_files["DejaVu"] = fpath

    # Register found fonts
    registered = {}
    for name, path in font_files.items():
        if path and os.path.exists(path):
            try:
                pdfmetrics.registerFont(TTFont(name, path$
                registered[name] = path
            except Exception:
                pass

    # Set fallbacks for missing fonts
    fallbacks = {
        "DejaVu": "Helvetica",
        "DejaVu-Bold": "Helvetica-Bold",
        "DejaVu-Italic": "Helvetica-Oblique",
        "DejaVu-BoldItalic": "Helvetica-BoldOblique",
        "DejaVuSerif-Bold": "Helvetica-Bold",
    }

    for name, fallback in fallbacks.items():
        if name not in registered:
            # Use fallback
            pass

    FONTS_REGISTERED = True
    return registered


def get_font_name(base_name: str) -> str:
    """Get font name with fallback."""
    register_fonts()
    # Check if font is available
    available_fonts = pdfmetrics.getRegisteredFontNames()
    if base_name in available_fonts:
        return base_name
    # Fallback
    fallbacks = {
        "DejaVu": "Helvetica",
        "DejaVu-Bold": "Helvetica-Bold",
        "DejaVu-Italic": "Helvetica-Oblique",
        "DejaVu-BoldItalic": "Helvetica-BoldOblique",
        "DejaVuSerif-Bold": "Helvetica-Bold",
    }
    return fallbacks.get(base_name, "Helvetica")


# ═══════════════════════════════════════════════════════════════════════════
# STYLE DEFINITIONS
# ═══════════════════════════════════════════════════════════════════════════

def get_styles(chapter_color: Color = None):
    """Get all paragraph styles for the document."""
    register_fonts()

    if chapter_color is None:
        chapter_color = get_color(0)

    styles = getSampleStyleSheet()

    # Helper to add style only if not already defined
    def add_style(name, **kwargs):
        if name not in styles:
            styles.add(ParagraphStyle(name, **kwargs))

    # Title style (for cover)
    add_style("CoverTitle",
        fontName=get_font_name("DejaVuSerif-Bold"), fontSize=32, leading=40,
        alignment=TA_CENTER, textColor=chapter_color, spaceAfter=10)
    add_style("CoverSubtitle",
        fontName=get_font_name("DejaVu"), fontSize=13, leading=18,
        alignment=TA_CENTER, textColor=HexColor("#757575"), spaceAfter=6)
    add_style("CoverAuthor",
        fontName=get_font_name("DejaVu"), fontSize=15, leading=20,
        alignment=TA_CENTER, textColor=HexColor("#424242"), spaceAfter=10)
    add_style("CoverInfo",
        fontName=get_font_name("DejaVu"), fontSize=10, leading=14,
        alignment=TA_CENTER, textColor=HexColor("#9E9E9E"), spaceAfter=4)
    add_style("CoverEdition",
        fontName=get_font_name("DejaVu-Bold"), fontSize=12, leading=16,
        alignment=TA_CENTER, textColor=HexColor("#C0392B"), spaceAfter=10)

    # Chapter title (inside banner)
    add_style("ChapterTitle",
        fontName=get_font_name("DejaVuSerif-Bold"), fontSize=22, leading=28,
        alignment=TA_CENTER, textColor=white, spaceAfter=2)
    add_style("ChapterSubtitle",
        fontName=get_font_name("DejaVu-Italic"), fontSize=11, leading=14,
        alignment=TA_CENTER, textColor=white, spaceAfter=2)
    add_style("ChapterNumber",
        fontName=get_font_name("DejaVu"), fontSize=9, leading=12,
        alignment=TA_LEFT, textColor=white)

    # Section header
    add_style("SectionHeader",
        fontName=get_font_name("DejaVu-Bold"), fontSize=12, leading=16,
        alignment=TA_LEFT, textColor=white)

    # Sub-section header
    add_style("SubSectionHeader",
        fontName=get_font_name("DejaVu-Bold"), fontSize=12, leading=16,
        alignment=TA_LEFT, textColor=chapter_color)

    # Body text
    add_style("BodyText",
        fontName=get_font_name("DejaVu"), fontSize=10, leading=15,
        alignment=TA_JUSTIFY, textColor=HexColor("#212121"), spaceAfter=3)
    add_style("BodyBold",
        fontName=get_font_name("DejaVu-Bold"), fontSize=10, leading=15,
        alignment=TA_JUSTIFY, textColor=HexColor("#212121"), spaceAfter=3)

    # Bullet level 1
    add_style("Bullet1",
        fontName=get_font_name("DejaVu"), fontSize=10, leading=15,
        alignment=TA_LEFT, textColor=HexColor("#212121"),
        leftIndent=15, spaceAfter=3, bulletIndent=5)

    # Bullet level 2
    add_style("Bullet2",
        fontName=get_font_name("DejaVu"), fontSize=10, leading=15,
        alignment=TA_LEFT, textColor=HexColor("#212121"),
        leftIndent=30, spaceAfter=3, bulletIndent=20)

    # Content box title
    add_style("BoxTitle",
        fontName=get_font_name("DejaVu-Bold"), fontSize=11, leading=14,
        alignment=TA_CENTER, textColor=white)
    add_style("BoxBody",
        fontName=get_font_name("DejaVu"), fontSize=9.5, leading=13,
        alignment=TA_JUSTIFY, textColor=HexColor("#212121"), spaceAfter=2)

    # Question text
    add_style("QuestionText",
        fontName=get_font_name("DejaVu-Bold"), fontSize=10, leading=14,
        alignment=TA_LEFT, textColor=HexColor("#212121"))
    add_style("AnswerText",
        fontName=get_font_name("DejaVu-Bold"), fontSize=10, leading=14,
        alignment=TA_LEFT, textColor=HexColor("#2E7D32"))
    add_style("ExplanationText",
        fontName=get_font_name("DejaVu-Italic"), fontSize=9, leading=12,
        alignment=TA_LEFT, textColor=HexColor("#37474F"))
    add_style("SlideRef",
        fontName=get_font_name("DejaVu-Italic"), fontSize=9, leading=12,
        alignment=TA_LEFT, textColor=HexColor("#E65100"))

    # Table header
    add_style("TableHeader",
        fontName=get_font_name("DejaVu-Bold"), fontSize=8.5, leading=11,
        alignment=TA_CENTER, textColor=white)
    add_style("TableBody",
        fontName=get_font_name("DejaVu"), fontSize=9, leading=12,
        alignment=TA_LEFT, textColor=HexColor("#212121"))

    # TOC styles
    add_style("TOCTitle",
        fontName=get_font_name("DejaVuSerif-Bold"), fontSize=24, leading=30,
        alignment=TA_CENTER, textColor=chapter_color, spaceAfter=20)
    add_style("TOCEntry",
        fontName=get_font_name("DejaVu"), fontSize=11, leading=16,
        alignment=TA_LEFT, textColor=HexColor("#212121"), spaceAfter=4)
    add_style("TOCEntryBold",
        fontName=get_font_name("DejaVu-Bold"), fontSize=11, leading=16,
        alignment=TA_LEFT, textColor=HexColor("#212121"), spaceAfter=4)

    # Footer
    add_style("Footer",
        fontName=get_font_name("DejaVu"), fontSize=8, leading=10,
        alignment=TA_CENTER, textColor=HexColor("#95A5A6"))

    return styles



# CHAPTER MARKER (for TOC)
# ═══════════════════════════════════════════════════════════════════════════

class ChapMarker(Flowable):
    """Invisible flowable that records chapter start page for TOC."""

    def __init__(self, chapter_num: int, chapter_title: str):
        Flowable.__init__(self)
        self.chapter_num = chapter_num
        self.chapter_title = chapter_title
        self.width = 0
        self.height = 0

    def draw(self):
        pass


# ═══════════════════════════════════════════════════════════════════════════
# CHAPTER BANNER
# ═══════════════════════════════════════════════════════════════════════════

def chapter_banner(chapter_num: int, title: str, subtitle: str = "",
                  color_index: int = 0, question_count: int = None):
    """
    Create a professional chapter banner.

    Args:
        chapter_num: Chapter number
        title: Chapter title
        subtitle: Optional subtitle
        color_index: Color palette index
        question_count: Optional question count badge

    Returns:
        List of flowables for the banner
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # Build banner content
    banner_data = []

    # Chapter number (top-left)
    chapter_num_text = f"Chapter {chapter_num}"
    banner_data.append([Paragraph(chapter_num_text, styles["ChapterNumber"])])

    # Title (centered, large)
    banner_data.append([Paragraph(title, styles["ChapterTitle"])])

    # Subtitle (if provided)
    if subtitle:
        banner_data.append([Paragraph(subtitle, styles["ChapterSubtitle"])])

    # Create banner table
    banner_table = Table(banner_data, colWidths=[140 * mm])
    banner_table.setStyle(TableStyle([
        ('BACKGROUND', (0, 0), (-1, -1), color),
        ('TOPPADDING', (0, 0), (-1, -1), 8),
        ('BOTTOMPADDING', (0, 0), (-1, -1), 8),
        ('LEFTPADDING', (0, 0), (-1, -1), 10),
        ('RIGHTPADDING', (0, 0), (-1, -1), 10),
        ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
        ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
    ]$

    elements.append(banner_table)

    # Bottom HR rule
    elements.append(HRFlowable(
        width="100%",
        thickness=2,
        color=color,
        spaceAfter=8,
        spaceBefore=2,
    $

    # Question count badge (if provided)
    if question_count:
        badge_data = [[Paragraph(f"{question_count} Questions", styles["ChapterNumber"])]]
        badge_table = Table(badge_data, colWidths=[40 * mm])
        badge_table.setStyle(TableStyle([
            ('BACKGROUND', (0, 0), (-1, -1), color),
            ('TOPPADDING', (0, 0), (-1, -1), 4),
            ('BOTTOMPADDING', (0, 0), (-1, -1), 4),
            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
        ]$
        elements.append(badge_table)

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# SECTION HEADER
# ═══════════════════════════════════════════════════════════════════════════

def section_header(title: str, color_index: int = 0):
    """
    Create a full-width colored section header.

    Args:
        title: Section title
        color_index: Color palette index

    Returns:
        List of flowables
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # Header bar
    header_data = [[Paragraph(title, styles["SectionHeader"])]]
    header_table = Table(header_data, colWidths=[140 * mm])
    header_table.setStyle(TableStyle([
        ('BACKGROUND', (0, 0), (-1, -1), color),
        ('TOPPADDING', (0, 0), (-1, -1), 6),
        ('BOTTOMPADDING', (0, 0), (-1, -1), 6),
        ('LEFTPADDING', (0, 0), (-1, -1), 10),
        ('RIGHTPADDING', (0, 0), (-1, -1), 10),
        ('ALIGN', (0, 0), (-1, -1), 'LEFT'),
        ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
    ]$

    elements.append(header_table)
    elements.append(Spacer(1, 2 * mm$

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# SUB-SECTION HEADER
# ═══════════════════════════════════════════════════════════════════════════

def sub_header(title: str, color_index: int = 0):
    """
    Create a sub-section header with colored accent rule.

    Args:
        title: Sub-section title
        color_index: Color palette index

    Returns:
        List of flowables
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # Title
    elements.append(Paragraph(title, styles["SubSectionHeader"]$

    # Accent rule (35% width)
    accent_width = 140 * mm * 0.35
    elements.append(HRFlowable(
        width=accent_width,
        thickness=1.5,
        color=color,
        spaceAfter=4,
        spaceBefore=1,
    $

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# CONTENT BOXES
# ═══════════════════════════════════════════════════════════════════════════

def content_box(title: str, content: str, box_type: str = "KTP",
                color_index: int = 0):
    """
    Create a styled content box.

    Args:
        title: Box title
        content: Box content (can be multi-line)
        box_type: Type of box (KTP, MCQ, IMPORTANT, OSCE)
        color_index: Color palette index

    Returns:
        List of flowables
    """
    # Box type colors
    box_colors = {
        "KTP": "#2196F3",      # Blue
        "MCQ": "#F44336",      # Red
        "IMPORTANT": "#FFC107", # Yellow/amber
        "OSCE": "#4CAF50",     # Green
    }

    border_color = HexColor(box_colors.get(box_type, "#2196F3"$
    bg_color = tint_color(box_colors.get(box_type, "#2196F3"), 0.1)
    styles = get_styles()

    elements = []

    # Parse content into paragraphs
    content_lines = content.strip().split('\n')

    # Build box data
    box_data = []

    # Title bar
    box_data.append([Paragraph(title, styles["BoxTitle"])])

    # Content
    for line in content_lines:
        line = line.strip()
        if line:
            box_data.append([Paragraph(line, styles["BoxBody"])])

    # Create box table
    box_table = Table(box_data, colWidths=[135 * mm])
    box_table.setStyle(TableStyle([
        # Title bar styling
        ('BACKGROUND', (0, 0), (-1, 0), border_color),
        ('TOPPADDING', (0, 0), (-1, 0), 6),
        ('BOTTOMPADDING', (0, 0), (-1, 0), 6),

        # Body styling
        ('BACKGROUND', (0, 1), (-1, -1), bg_color),
        ('TOPPADDING', (0, 1), (-1, -1), 6),
        ('BOTTOMPADDING', (0, 1), (-1, -1), 6),
        ('LEFTPADDING', (0, 0), (-1, -1), 6),
        ('RIGHTPADDING', (0, 0), (-1, -1), 6),

        # Border
        ('BOX', (0, 0), (-1, -1), 1.5, border_color),
        ('LINEBELOW', (0, 0), (-1, 0), 0, border_color),

        # Alignment
        ('ALIGN', (0, 0), (-1, 0), 'CENTER'),
        ('VALIGN', (0, 0), (-1, -1), 'TOP'),
    ]$

    elements.append(box_table)
    elements.append(Spacer(1, 4 * mm$

    return elements


def key_teaching_points(content: str):
    """Create a Key Teaching Points box."""
    return content_box("KEY TEACHING POINTS", content, "KTP")


def mcq_traps(content: str):
    """Create an MCQ Traps box."""
    return content_box("MCQ TRAPS & PITFALLS", content, "MCQ")


def important_box(content: str):
    """Create an Important box."""
    return content_box("IMPORTANT", content, "IMPORTANT")


def osce_pearls(content: str):
    """Create an OSCE Pearls box."""
    return content_box("OSCE PEARLS", content, "OSCE")


# ═══════════════════════════════════════════════════════════════════════════
# QUESTION BOX (Past Paper Style)
# ═══════════════════════════════════════════════════════════════════════════

def question_box(question: str, answer: str, explanation: str = "",
                 slide_ref: str = "", choices: list = None):
    """
    Create a past paper style question box.

    Args:
        question: Question text
        answer: Correct answer
        explanation: Explanation text
        slide_ref: Slide reference
        choices: List of answer choices

    Returns:
        List of flowables
    """
    styles = get_styles()
    elements = []

    # Build question data
    q_data = []

    # Question row (light gray background)
    q_data.append([Paragraph(f"Q: {question}", styles["QuestionText"])])

    # Choices (if provided)
    if choices:
        for i, choice in enumerate(choices):
            choice_letter = chr(65 + i)  # A, B, C, D...
            q_data.append([Paragraph(f"   {choice_letter}. {choice}", styles["BodyText"])])

    # Answer row
    q_data.append([Paragraph(f"Answer: {answer}", styles["AnswerText"])])

    # Explanation (if provided)
    if explanation:
        q_data.append([Paragraph(f"Explanation: {explanation}", styles["ExplanationText"])])

    # Slide reference (if provided)
    if slide_ref:
        q_data.append([Paragraph(f"▶ Slide: {slide_ref}", styles["SlideRef"])])

    # Create question table
    q_table = Table(q_data, colWidths=[135 * mm])
    q_table.setStyle(TableStyle([
        # Outer border
        ('BOX', (0, 0), (-1, -1), 0.5, HexColor("#D5D8DC"$,

        # Question row background
        ('BACKGROUND', (0, 0), (-1, 0), HexColor("#F2F3F4"$,
        ('TOPPADDING', (0, 0), (-1, 0), 6),
        ('BOTTOMPADDING', (0, 0), (-1, 0), 6),

        # Padding
        ('TOPPADDING', (0, 1), (-1, -1), 4),
        ('BOTTOMPADDING', (0, 1), (-1, -1), 4),
        ('LEFTPADDING', (0, 0), (-1, -1), 6),
        ('RIGHTPADDING', (0, 0), (-1, -1), 6),

        # Alignment
        ('VALIGN', (0, 0), (-1, -1), 'TOP'),
    ]$

    elements.append(q_table)
    elements.append(Spacer(1, 1.5 * mm$

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# PROFESSIONAL TABLE
# ═══════════════════════════════════════════════════════════════════════════

def professional_table(headers: list, rows: list, color_index: int = 0):
    """
    Create a professional styled table.

    Args:
        headers: List of column headers
        rows: List of row data (each row is a list of cell values)
        color_index: Color palette index

    Returns:
        List of flowables
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # Build table data
    table_data = []

    # Header row
    header_cells = [Paragraph(h, styles["TableHeader"]) for h in headers]
    table_data.append(header_cells)

    # Body rows
    for row in rows:
        row_cells = [Paragraph(str(cell), styles["TableBody"]) for cell in row]
        table_data.append(row_cells)

    # Calculate column widths
    num_cols = len(headers)
    col_width = 140 * mm / num_cols
    col_widths = [col_width] * num_cols

    # Create table
    table = Table(table_data, colWidths=col_widths, repeatRows=1)

    # Build table style
    style_commands = [
        # Header styling
        ('BACKGROUND', (0, 0), (-1, 0), color),
        ('TOPPADDING', (0, 0), (-1, 0), 5),
        ('BOTTOMPADDING', (0, 0), (-1, 0), 5),

        # Body padding
        ('TOPPADDING', (0, 1), (-1, -1), 5),
        ('BOTTOMPADDING', (0, 1), (-1, -1), 5),
        ('LEFTPADDING', (0, 0), (-1, -1), 6),
        ('RIGHTPADDING', (0, 0), (-1, -1), 6),

        # Grid
        ('INNERGRID', (0, 0), (-1, -1), 0.5, HexColor("#BDBDBD"$,
        ('BOX', (0, 0), (-1, -1), 0.8, color),

        # Alignment
        ('ALIGN', (0, 0), (-1, 0), 'CENTER'),
        ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
    ]

    # Alternating row colors
    for i in range(1, len(table_data$:
        if i % 2 == 0:
            style_commands.append(
                ('BACKGROUND', (0, i), (-1, i), HexColor("#F8F9F9"$
            )

    table.setStyle(TableStyle(style_commands$

    elements.append(table)
    elements.append(Spacer(1, 4 * mm$

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# COVER PAGE
# ═══════════════════════════════════════════════════════════════════════════

def cover_page(title: str, subtitle: str = "", author: str = "",
               info_lines: list = None, edition: str = "",
               color_index: int = 0):
    """
    Create a professional cover page.

    Args:
        title: Document title
        subtitle: Document subtitle
        author: Author name
        info_lines: List of info lines
        edition: Edition text
        color_index: Color palette index

    Returns:
        List of flowables
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # Top spacer
    elements.append(Spacer(1, 40 * mm$

    # Title
    elements.append(Paragraph(title, styles["CoverTitle"]$

    # Subtitle
    if subtitle:
        elements.append(Paragraph(subtitle, styles["CoverSubtitle"]$

    # Author
    if author:
        elements.append(Paragraph(author, styles["CoverAuthor"]$

    # Accent rule (50% width)
    elements.append(Spacer(1, 10 * mm$
    accent_width = 140 * mm * 0.5
    elements.append(HRFlowable(
        width=accent_width,
        thickness=2,
        color=color,
        spaceAfter=10,
        spaceBefore=5,
    $

    # Info lines
    if info_lines:
        for line in info_lines:
            elements.append(Paragraph(line, styles["CoverInfo"]$

    # Edition
    if edition:
        elements.append(Spacer(1, 15 * mm$
        elements.append(Paragraph(edition, styles["CoverEdition"]$

    # Page break
    elements.append(Spacer(1, 60 * mm$

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# TOC BUILDER
# ═══════════════════════════════════════════════════════════════════════════

def toc_page(toc_entries: list, color_index: int = 0):
    """
    Create a table of contents page.

    Args:
        toc_entries: List of (chapter_num, title, page_num) tuples
        color_index: Color palette index

    Returns:
        List of flowables
    """
    color = get_color(color_index)
    styles = get_styles(color)

    elements = []

    # TOC Title
    elements.append(Paragraph("Table of Contents", styles["TOCTitle"]$
    elements.append(Spacer(1, 10 * mm$

    # TOC entries
    for chapter_num, title, page_num in toc_entries:
        entry_text = f"Chapter {chapter_num}: {title}"
        elements.append(Paragraph(entry_text, styles["TOCEntry"]$
        elements.append(Paragraph(f"  Page {page_num}", styles["CoverInfo"]$

    return elements


# ═══════════════════════════════════════════════════════════════════════════
# BODY TEXT HELPERS
# ═══════════════════════════════════════════════════════════════════════════

def body_paragraph(text: str, style: str = "BodyText"):
    """Create a body text paragraph."""
    styles = get_styles()
    return Paragraph(text, styles[style])


def bullet_item(text: str, level: int = 1):
    """Create a bullet point."""
    styles = get_styles()
    style_name = f"Bullet{level}"
    bullet_char = "•" if level == 1 else "◦"
    return Paragraph(f"{bullet_char} {text}", styles[style_name])


# ═══════════════════════════════════════════════════════════════════════════
# FOOTER DRAW FUNCTION
# ═══════════════════════════════════════════════════════════════════════════

def draw_footer(canvas, doc, title: str = ""):
    """Draw footer on each page."""
    canvas.saveState()

    # Top line
    canvas.setStrokeColor(HexColor("#BDC3C7"$
    canvas.setLineWidth(0.5)
    canvas.line(18 * mm, 22 * mm, 192 * mm, 22 * mm)

    # Page number (centered)
    canvas.setFont(get_font_name("DejaVu"), 8)
    canvas.setFillColor(HexColor("#95A5A6"$
    page_num = canvas.getPageNumber()
    canvas.drawCentredString(105 * mm, 15 * mm, str(page_num$

    # Document title (right-aligned)
    if title:
        canvas.drawRightString(190 * mm, 15 * mm, title)

    canvas.restoreState()


# ═══════════════════════════════════════════════════════════════════════════
# PDF BUILDER CLASS
# ═══════════════════════════════════════════════════════════════════════════

class PDFBuilder:
    """Main PDF builder class with two-pass support."""

    def __init__(self, output_path: str, title: str = "",
                 color_index: int = 0):
        self.output_path = output_path
        self.title = title
        self.color_index = color_index
        self.color = get_color(color_index)
        self.styles = get_styles(self.color)
        self.story = []
        self.chapters = []  # (chapter_num, title, page_num)
        self.markers = []  # ChapMarker instances

    def add_chapter(self, chapter_num: int, title: str, subtitle: str = "",
                    content: list = None):
        """Add a chapter to the document."""
        # Add chapter marker for TOC
        marker = ChapMarker(chapter_num, title)
        self.markers.append(marker)
        self.story.append(marker)

        # Add chapter banner
        banner_elements = chapter_banner(
            chapter_num, title, subtitle,
            color_index=self.color_index + chapter_num
        )
        self.story.extend(banner_elements)

        # Add content
        if content:
            self.story.extend(content)

    def add_section(self, title: str):
        """Add a section header."""
        elements = section_header(title, self.color_index)
        self.story.extend(elements)

    def add_subsection(self, title: str):
        """Add a sub-section header."""
        elements = sub_header(title, self.color_index)
        self.story.extend(elements)

    def add_paragraph(self, text: str, style: str = "BodyText"):
        """Add a body paragraph."""
        self.story.append(Paragraph(text, self.styles[style]$

    def add_bullet(self, text: str, level: int = 1):
        """Add a bullet point."""
        self.story.append(bullet_item(text, level$

    def add_content_box(self, title: str, content: str, box_type: str = "KTP"):
        """Add a content box."""
        elements = content_box(title, content, box_type, self.color_index)
        self.story.extend(elements)

    def add_question(self, question: str, answer: str, explanation: str = "",
                     slide_ref: str = "", choices: list = None):
        """Add a question box."""
        elements = question_box(question, answer, explanation, slide_ref, choices)
        self.story.extend(elements)

    def add_table(self, headers: list, rows: list):
        """Add a professional table."""
        elements = professional_table(headers, rows, self.color_index)
        self.story.extend(elements)

    def add_cover(self, title: str, subtitle: str = "", author: str = "",
                  info_lines: list = None, edition: str = ""):
        """Add a cover page."""
        elements = cover_page(title, subtitle, author, info_lines, edition,
                              self.color_index)
        self.story.extend(elements)

    def add_toc(self, toc_entries: list):
        """Add a table of contents page."""
        elements = toc_page(toc_entries, self.color_index)
        self.story.extend(elements)

    def build(self):
        """Build the PDF document."""
        # Create document
        doc = SimpleDocTemplate(
            self.output_path,
            pagesize=A4,
            leftMargin=18 * mm,
            rightMargin=18 * mm,
            topMargin=18 * mm,
            bottomMargin=22 * mm,
        )

        # Create frame
        frame = Frame(
            18 * mm, 22 * mm,
            174 * mm, 257 * mm,
            id='normal',
            showBoundary=0,
        )

        # Create page template with footer
        template = PageTemplate(
            id='main',
            frames=frame,
            onPage=lambda canvas, doc: draw_footer(canvas, doc, self.title),
        )
        doc.addPageTemplates([template])

        # Build document
        doc.build(self.story)

        return self.output_path


# ═══════════════════════════════════════════════════════════════════════════
# TWO-PASS BUILDER (for TOC with correct page numbers)
# ═══════════════════════════════════════════════════════════════════════════

class TwoPassPDFBuilder:
    """Two-pass PDF builder for accurate TOC page numbers."""

    def __init__(self, output_path: str, title: str = "",
                 color_index: int = 0):
        self.output_path = output_path
        self.title = title
        self.color_index = color_index
        self.color = get_color(color_index)
        self.styles = get_styles(self.color)
        self.story = []
        self.chapter_markers = []  # (chapter_num, title, marker_index)

    def add_chapter(self, chapter_num: int, title: str, subtitle: str = "",
                    content: list = None):
        """Add a chapter."""
        marker = ChapMarker(chapter_num, title)
        self.chapter_markers.append((chapter_num, title, len(self.story$)
        self.story.append(marker)

        banner_elements = chapter_banner(
            chapter_num, title, subtitle,
            color_index=self.color_index + chapter_num
        )
        self.story.extend(banner_elements)

        if content:
            self.story.extend(content)

    def add_section(self, title: str):
        """Add a section header."""
        self.story.extend(section_header(title, self.color_index$

    def add_subsection(self, title: str):
        """Add a sub-section header."""
        self.story.extend(sub_header(title, self.color_index$

    def add_paragraph(self, text: str, style: str = "BodyText"):
        """Add a body paragraph."""
        self.story.append(Paragraph(text, self.styles[style]$

    def add_bullet(self, text: str, level: int = 1):
        """Add a bullet point."""
        self.story.append(bullet_item(text, level$

    def add_content_box(self, title: str, content: str, box_type: str = "KTP"):
        """Add a content box."""
        self.story.extend(content_box(title, content, box_type, self.color_index$

    def add_question(self, question: str, answer: str, explanation: str = "",
                     slide_ref: str = "", choices: list = None):
        """Add a question box."""
        self.story.extend(question_box(question, answer, explanation, slide_ref, choices$

    def add_table(self, headers: list, rows: list):
        """Add a professional table."""
        self.story.extend(professional_table(headers, rows, self.color_index$

    def add_cover(self, title: str, subtitle: str = "", author: str = "",
                  info_lines: list = None, edition: str = ""):
        """Add a cover page."""
        self.story.extend(cover_page(title, subtitle, author, info_lines, edition,
                                     self.color_index$

    def build(self):
        """Build PDF with two-pass for TOC."""
        # Pass 1: Build to get page numbers
        temp_path = self.output_path + ".temp.pdf"
        doc = SimpleDocTemplate(
            temp_path,
            pagesize=A4,
            leftMargin=18 * mm,
            rightMargin=18 * mm,
            topMargin=18 * mm,
            bottomMargin=22 * mm,
        )

        frame = Frame(18 * mm, 22 * mm, 174 * mm, 257 * mm, id='normal')
        template = PageTemplate(id='main', frames=frame)
        doc.addPageTemplates([template])

        # Build first pass
        doc.build(self.story)

        # Get page numbers for chapters
        # (In a real implementation, you'd parse the PDF to get actual page numbers)
        # For now, we'll use estimated page numbers

        # Pass 2: Build final with TOC
        doc2 = SimpleDocTemplate(
            self.output_path,
            pagesize=A4,
            leftMargin=18 * mm,
            rightMargin=18 * mm,
            topMargin=18 * mm,
            bottomMargin=22 * mm,
        )

        frame2 = Frame(18 * mm, 22 * mm, 174 * mm, 257 * mm, id='normal')
        template2 = PageTemplate(
            id='main',
            frames=frame2,
            onPage=lambda canvas, doc: draw_footer(canvas, doc, self.title),
        )
        doc2.addPageTemplates([template2])

        # Build final
        doc2.build(self.story)

        # Clean up temp file
        if os.path.exists(temp_path):
            os.remove(temp_path)

        return self.output_path


# ═══════════════════════════════════════════════════════════════════════════
# UTILITY FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════

def clean_text(text: str) -> str:
    """Clean text for PDF rendering."""
    # Remove excessive whitespace
    text = re.sub(r'\s+', ' ', text)
    # Fix common issues
    text = re.sub(r'-\s+', '', text)  # Fix hyphenated words
    return text.strip()


def escape_xml(text: str) -> str:
    """Escape XML special characters for ReportLab."""
    text = text.replace('&', '&amp;')
    text = text.replace('<', '&lt;')
    text = text.replace('>', '&gt;')
    text = text.replace('"', '&quot;')
    return text


